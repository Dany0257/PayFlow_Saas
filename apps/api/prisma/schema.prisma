// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum Role {
  ADMIN
  BUSINESS
  CLIENT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  PAYPAL
  MOBILE_MONEY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// ============ MODELS ============

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      Role     @default(BUSINESS)
  business  Business?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Business {
  id        String    @id @default(cuid())
  name      String
  logo      String?
  address   String?
  city      String?
  country   String    @default("FR")
  phone     String
  siret     String?   // Numéro SIRET pour la France
  vatNumber String?   // Numéro de TVA
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  clients   Client[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("businesses")
}

model Client {
  id         String    @id @default(cuid())
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  country    String    @default("FR")
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices   Invoice[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("clients")
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  status      InvoiceStatus @default(DRAFT)
  amount      Decimal       @db.Decimal(10, 2)
  taxRate     Decimal       @default(0) @db.Decimal(5, 2)
  taxAmount   Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount Decimal       @db.Decimal(10, 2)
  currency    String        @default("EUR")
  dueDate     DateTime
  notes       String?
  items       InvoiceItem[]
  payments    Payment[]
  businessId  String
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  publicToken String        @unique @default(cuid())
  sentAt      DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("EUR")
  method        PaymentMethod
  provider      String        // "stripe", "paypal", "flutterwave"
  providerRef   String?       // ID de transaction du provider
  status        PaymentStatus @default(PENDING)
  metadata      Json?         // Données additionnelles du provider
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // "sms", "whatsapp", "email"
  recipient String   // Numéro de téléphone ou email
  subject   String?
  message   String
  status    String   @default("pending") // "pending", "sent", "failed"
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}
